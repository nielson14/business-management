Net Profit/Loss: ${netProfit>=0?'+':''}$${netProfit.toFixed(2)}
Cups sold: ${totalCupsSold} | Cups wasted: ${totalUnsold}
Profitable days: ${profitDays}/14
Average price: $${avgPrice}
Best day: Day ${bestDay.day} (+$${bestDay.profit.toFixed(2)})
Worst day: Day ${worstDay.day} ($${worstDay.profit.toFixed(2)})
Final reputation: ${Math.round((state.reputation/100)*5)}/5

Daily decisions:
${decisionSummary}`;

  try{
    const res=await fetch(WORKER_URL,{method:'POST',headers:{'Content-Type':'application/json'},
      body:JSON.stringify({model:'claude-haiku-4-5-20251001',max_tokens:1000,
        messages:[{role:'user',content:systemPrompt+'\n\n'+userPrompt}]})});
    const data=await res.json();
    const text=data.content?.[0]?.text||'Could not generate feedback.';
