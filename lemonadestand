// ── COMPUTED PRICES ──
function getPrice(item){
  const base=BASE_PRICES[item];
  if(item==='cups')return base*state.cupCostMult;
  return base;
}

function calcCostPreview(){
  const {lemons,sugar,cups,water}=dayDecisions;
  const lCost=lemons>=BULK_DISCOUNT.lemons.qty?lemons*BULK_DISCOUNT.lemons.price:lemons*getPrice('lemons');
  const sCost=sugar>=BULK_DISCOUNT.sugar.qty?sugar*BULK_DISCOUNT.sugar.price:sugar*getPrice('sugar');
  const cCost=cups>=BULK_DISCOUNT.cups.qty?cups*BULK_DISCOUNT.cups.price:cups*getPrice('cups');
  const wCost=water*getPrice('water');
  const mktCost=MARKETING.find(m=>m.id===dayDecisions.marketing)?.cost||0;
  return{lCost,sCost,cCost,wCost,mktCost,total:lCost+sCost+cCost+wCost+mktCost};
}

function getSupplyCost(item,qty){
  const bulk=BULK_DISCOUNT[item];
  if(bulk&&qty>=bulk.qty)return qty*bulk.price;
  return qty*getPrice(item);
}

// ── CUPS PER BATCH ──
// 1 lemon + sugar(recipe) + 1 cup + water per 2 cups of lemonade
function maxCupsFromSupplies(l,s,c,w){
  const recipe=dayDecisions.recipe/100;
  const fromLemons=Math.floor(l*2);
  const fromSugar=recipe>0?Math.floor(s/(recipe*0.5)):999;
  const fromCups=c;
  const fromWater=Math.floor(w*8);
  return Math.min(fromLemons,fromSugar,fromCups,fromWater);
}

// ── DEMAND CALCULATION ──
function calcDemand(day){
  const weather=WEATHER_TYPES[WEATHER_SCHEDULE[day-1]];
  const loc=LOCATIONS.find(l=>l.id===dayDecisions.location)||LOCATIONS[0];
  const mkt=MARKETING.find(m=>m.id===dayDecisions.marketing)||MARKETING[0];
  const event=RANDOM_EVENTS.find(e=>e.day===day);

  let baseDemand=30;
  // Weather
  baseDemand*=weather.demandMult;
  // Location
  baseDemand*=loc.mult;
  // Beach on hot day bonus
  if(dayDecisions.location==='beach'&&(WEATHER_SCHEDULE[day-1]==='hot'||WEATHER_SCHEDULE[day-1]==='perfect'))baseDemand*=1.3;
  // Market only weekends (days 6,7,13,14)
  if(dayDecisions.location==='market'&&![6,7,13,14].includes(day))baseDemand*=0.4;
  // Marketing
  baseDemand*=(1+mkt.demandBonus);
  // Reputation
  baseDemand*=(0.7+(state.reputation/100)*0.6);
  // Recipe — sweet spot is 40-60, too sweet or too tart loses customers
  const recipeScore=1-Math.abs(dayDecisions.recipe-50)/100;
  baseDemand*=(0.7+recipeScore*0.6);
  // Price elasticity — higher price = fewer customers
  const priceEffect=Math.max(0.2,1.5-(dayDecisions.price*0.8));
  baseDemand*=priceEffect;
  // Competition
  if(state.hasCompetitor&&day>=COMPETITION_DAY)baseDemand*=0.82;
  // Event bonuses
  if(event?.effect?.demandMult)baseDemand*=event.effect.demandMult;
  if(event?.effect?.demandBonus)baseDemand*=(1+event.effect.demandBonus);
  // Day 1 grace
  if(day===1)baseDemand=Math.max(baseDemand,15);

  return Math.max(1,Math.round(baseDemand+(Math.random()-0.5)*8));
}

