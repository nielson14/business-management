// ── OPEN FOR BUSINESS ──
function openForBusiness(){
  const costs=calcCostPreview();
  if(state.cash<costs.total){alert('Not enough cash!');return;}

  // Pay for supplies
  state.cash-=costs.total;

  // Add to carry-over stock
  state.supplies.lemons+=dayDecisions.lemons;
  state.supplies.sugar+=dayDecisions.sugar;
  state.supplies.cups+=dayDecisions.cups;
  state.supplies.water+=dayDecisions.water;

  // Calculate what we can make
  const maxCups=maxCupsFromSupplies(state.supplies.lemons,state.supplies.sugar,state.supplies.cups,state.supplies.water);

  // Calculate demand
  const demand=calcDemand(state.day);
  const cupsSold=Math.min(maxCups,demand);
  const cupsUnsold=maxCups-cupsSold;

  // Revenue
  const revenue=cupsSold*dayDecisions.price;

  // Event cash penalty
  const event=RANDOM_EVENTS.find(e=>e.day===state.day);
  let penalty=0;
  if(event?.effect?.cashPenalty){penalty=event.effect.cashPenalty;state.cash=Math.max(0,state.cash-penalty);}

  // Total daily expenses = supply cost + marketing + penalty
  const mktCost=MARKETING.find(m=>m.id===dayDecisions.marketing)?.cost||0;
  const totalExpenses=costs.total+penalty;
  const profit=revenue-totalExpenses;

  state.cash+=revenue;

  // Consume supplies
  const lemons_used=Math.ceil(cupsSold/2);
  const sugar_used=Math.ceil(cupsSold*(dayDecisions.recipe/100)*0.5);
  const cups_used=cupsSold;
  const water_used=Math.ceil(cupsSold/8);
  state.supplies.lemons=Math.max(0,state.supplies.lemons-lemons_used);
  state.supplies.sugar=Math.max(0,state.supplies.sugar-sugar_used);
  state.supplies.cups=Math.max(0,state.supplies.cups-cups_used);
  state.supplies.water=Math.max(0,state.supplies.water-water_used);

  // Competition appears Day 4
  if(state.day===COMPETITION_DAY-1)state.hasCompetitor=true;

  // Cup shortage event reset
  state.cupCostMult=1;
  if(event?.effect?.cupCostMult)state.cupCostMult=event.effect.cupCostMult;

  // Reputation update
  const soldRatio=maxCups>0?cupsSold/maxCups:0;
  const priceScore=dayDecisions.price<=1.50?1:dayDecisions.price<=2.00?0.7:0.4;
  const recipeScore=Math.abs(dayDecisions.recipe-50)<20?1:Math.abs(dayDecisions.recipe-50)<40?0.7:0.4;
  const repChange=Math.round((soldRatio*10+priceScore*5+recipeScore*5-7)*(1+Math.random()*0.3));
  state.reputation=Math.max(10,Math.min(100,state.reputation+repChange));

  // Save history
  const weatherKey=WEATHER_SCHEDULE[state.day-1];
  state.history.push({
    day:state.day,weatherKey,
    supplySpend:costs.total,mktCost,penalty,totalExpenses,
    revenue,profit,
    cupsMade:maxCups,cupsSold,cupsUnsold,
    price:dayDecisions.price,recipe:dayDecisions.recipe,
    location:dayDecisions.location,marketing:dayDecisions.marketing,
    demand,reputation:state.reputation,
  });

  renderDaySummary(state.history[state.history.length-1]);
}

