<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Lemonade Stand — Business Simulation</title>
<link href="https://fonts.googleapis.com/css2?family=Fredoka:wght@300;400;500;600;700&family=Nunito:ital,wght@0,400;0,600;0,700;0,800;1,400&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
:root{
  --sky:#87CEEB;--sun:#FFD700;--grass:#4CAF50;--stand:#D2691E;
  --bg:#FFF9F0;--surface:#FFFFFF;--surface2:#FFF3E0;--surface3:#FFE0B2;
  --border:#F0D9B5;--text:#2D1B00;--text-muted:#8B6914;--text-dim:#C4A44A;
  --lemon:#FFD700;--lemon-dark:#FFA000;
  --green:#2E7D32;--greenl:#E8F5E9;
  --red:#C62828;--redl:#FFEBEE;
  --blue:#1565C0;--bluel:#E3F2FD;
  --purple:#6A1B9A;--purplel:#F3E5F5;
  --orange:#E65100;--orangel:#FFF3E0;
  --radius:14px;--radius-sm:8px;
  --display:'Fredoka',sans-serif;--body:'Nunito',sans-serif;
}
body{font-family:var(--body);background:var(--bg);color:var(--text);min-height:100vh;overflow-x:hidden;}

/* ── SCENE ── */
.scene{position:relative;height:200px;background:linear-gradient(180deg,#87CEEB 0%,#B0E2FF 60%,#4CAF50 60%,#388E3C 100%);overflow:hidden;flex-shrink:0;}
.sun{position:absolute;top:18px;right:60px;font-size:3rem;transition:all .5s;}
.cloud{position:absolute;font-size:2rem;opacity:.85;transition:all 1s;}
.stand-img{position:absolute;bottom:40px;left:50%;transform:translateX(-50%);font-size:5rem;filter:drop-shadow(2px 4px 6px rgba(0,0,0,.3));transition:all .4s;}
.scene-label{position:absolute;bottom:8px;left:50%;transform:translateX(-50%);background:rgba(255,255,255,.75);border-radius:100px;padding:.2rem .85rem;font-size:.72rem;font-weight:700;color:var(--text-muted);white-space:nowrap;}
.weather-overlay{position:absolute;inset:0;pointer-events:none;transition:all .5s;}
.rain-drop{position:absolute;width:2px;height:12px;background:rgba(100,150,255,.5);border-radius:1px;animation:rain .6s linear infinite;}
@keyframes rain{from{transform:translateY(-20px)}to{transform:translateY(210px)}}
.customer-parade{position:absolute;bottom:44px;left:0;right:0;height:40px;overflow:hidden;}
.customer{position:absolute;font-size:1.4rem;bottom:0;animation:walk 3s linear forwards;}
@keyframes walk{from{left:110%}to{left:-10%}}

/* ── HEADER ── */
.game-header{background:var(--lemon-dark);color:#fff;padding:.75rem 1.5rem;display:flex;align-items:center;gap:1.25rem;flex-wrap:wrap;position:sticky;top:0;z-index:100;box-shadow:0 2px 8px rgba(0,0,0,.15);}
.game-title{font-family:var(--display);font-size:1.4rem;font-weight:600;color:#fff;display:flex;align-items:center;gap:.5rem;}
.day-badge{background:rgba(255,255,255,.2);border-radius:100px;padding:.3rem .9rem;font-family:var(--display);font-size:.85rem;font-weight:600;white-space:nowrap;}
.stat-pill{background:rgba(255,255,255,.15);border-radius:100px;padding:.3rem .85rem;font-size:.8rem;font-weight:700;display:flex;align-items:center;gap:.4rem;white-space:nowrap;}
.stat-pill.cash{background:rgba(255,255,255,.9);color:var(--lemon-dark);}
.stat-pill .icon{font-size:.9rem;}
.progress-wrap{flex:1;min-width:120px;height:8px;background:rgba(255,255,255,.2);border-radius:100px;overflow:hidden;}
.progress-fill{height:100%;border-radius:100px;background:rgba(255,255,255,.8);transition:width .4s ease;}

/* ── MAIN LAYOUT ── */
.game-body{display:grid;grid-template-columns:260px 1fr;min-height:calc(100vh - 58px - 200px);}
.left-panel{background:var(--surface);border-right:2px solid var(--border);padding:1.25rem;display:flex;flex-direction:column;gap:1.25rem;overflow-y:auto;}
.right-panel{padding:1.5rem;overflow-y:auto;display:flex;flex-direction:column;gap:1.25rem;}

/* ── CARDS ── */
.card{background:var(--surface);border:2px solid var(--border);border-radius:var(--radius);padding:1.25rem;}
.card-title{font-family:var(--display);font-size:1rem;font-weight:600;margin-bottom:.85rem;display:flex;align-items:center;gap:.4rem;}

/* ── WEATHER FORECAST ── */
.forecast-row{display:flex;gap:.35rem;flex-wrap:wrap;}
.fc-day{display:flex;flex-direction:column;align-items:center;gap:.15rem;padding:.4rem .35rem;border-radius:var(--radius-sm);background:var(--surface2);border:1px solid var(--border);min-width:38px;}
.fc-day.today{border-color:var(--lemon-dark);background:var(--orangel);}
.fc-day.past{opacity:.45;}
.fc-num{font-size:.6rem;font-weight:700;color:var(--text-muted);}
.fc-icon{font-size:1rem;}
.fc-temp{font-size:.58rem;color:var(--text-muted);}

/* ── REPUTATION ── */
.rep-bar-wrap{height:12px;background:var(--surface2);border-radius:100px;overflow:hidden;border:1px solid var(--border);}
.rep-bar-fill{height:100%;border-radius:100px;background:linear-gradient(90deg,#FF5722,#FFD700,#4CAF50);transition:width .5s ease;}
.rep-stars{display:flex;gap:.15rem;font-size:1.1rem;}

/* ── SUPPLY MARKET ── */
.supply-grid{display:grid;grid-template-columns:1fr 1fr;gap:.6rem;}
.supply-item{background:var(--surface2);border:2px solid var(--border);border-radius:var(--radius-sm);padding:.75rem;text-align:center;position:relative;}
.supply-emoji{font-size:1.75rem;margin-bottom:.25rem;}
.supply-name{font-size:.72rem;font-weight:700;margin-bottom:.15rem;}
.supply-price{font-size:.65rem;color:var(--text-muted);margin-bottom:.5rem;}
.supply-controls{display:flex;align-items:center;justify-content:center;gap:.4rem;}
.qty-btn{width:26px;height:26px;border-radius:50%;border:2px solid var(--border);background:var(--surface);font-size:.9rem;font-weight:700;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all .15s;color:var(--text);}
.qty-btn:hover{border-color:var(--lemon-dark);background:var(--orangel);}
.qty-val{font-family:var(--display);font-size:1rem;font-weight:600;min-width:24px;text-align:center;}
.supply-subtotal{font-size:.65rem;color:var(--text-muted);margin-top:.35rem;}
.bulk-badge{position:absolute;top:4px;right:4px;font-size:.55rem;font-weight:700;background:var(--green);color:#fff;border-radius:100px;padding:.1rem .4rem;}

/* ── DECISION SLIDERS ── */
.slider-row{margin-bottom:1rem;}
.slider-header{display:flex;justify-content:space-between;align-items:baseline;margin-bottom:.35rem;}
.slider-label{font-size:.78rem;font-weight:700;color:var(--text);}
.slider-val{font-family:var(--display);font-size:1rem;font-weight:600;color:var(--lemon-dark);}
input[type=range]{-webkit-appearance:none;width:100%;height:6px;background:var(--surface2);border-radius:3px;outline:none;border:1px solid var(--border);}
input[type=range]::-webkit-slider-thumb{-webkit-appearance:none;width:20px;height:20px;border-radius:50%;background:var(--lemon-dark);cursor:pointer;border:3px solid #fff;box-shadow:0 2px 6px rgba(0,0,0,.2);}
.slider-labels{display:flex;justify-content:space-between;font-size:.6rem;color:var(--text-muted);margin-top:.2rem;}

/* ── LOCATION PICKER ── */
.location-grid{display:grid;grid-template-columns:1fr 1fr;gap:.5rem;}
.loc-opt{padding:.6rem .5rem;border:2px solid var(--border);border-radius:var(--radius-sm);cursor:pointer;transition:all .15s;text-align:center;}
.loc-opt:hover{border-color:var(--lemon-dark);}
.loc-opt.selected{border-color:var(--lemon-dark);background:var(--orangel);}
.loc-emoji{font-size:1.2rem;}
.loc-name{font-size:.7rem;font-weight:700;margin-top:.15rem;}
.loc-bonus{font-size:.58rem;color:var(--text-muted);}

/* ── COST PREVIEW ── */
.cost-preview{background:var(--surface2);border:2px solid var(--border);border-radius:var(--radius-sm);padding:.85rem;font-size:.82rem;}
.cost-row{display:flex;justify-content:space-between;align-items:center;padding:.2rem 0;border-bottom:1px dashed var(--border);}
.cost-row:last-child{border-bottom:none;font-weight:700;}
.cost-label{color:var(--text-muted);}
.cost-val{}
.cost-val.danger{color:var(--red);font-weight:700;}
.cost-val.ok{color:var(--green);font-weight:700;}

/* ── MARKETING ── */
.marketing-opts{display:flex;flex-direction:column;gap:.4rem;}
.mkt-opt{display:flex;align-items:center;gap:.65rem;padding:.55rem .7rem;border:2px solid var(--border);border-radius:var(--radius-sm);cursor:pointer;transition:all .15s;}
.mkt-opt:hover{border-color:var(--purple);}
.mkt-opt.selected{border-color:var(--purple);background:var(--purplel);}
.mkt-opt input[type=radio]{accent-color:var(--purple);width:14px;height:14px;flex-shrink:0;}
.mkt-text{flex:1;}
.mkt-name{font-size:.78rem;font-weight:700;}
.mkt-name.selected-text{color:var(--purple);}
.mkt-desc{font-size:.62rem;color:var(--text-muted);}
.mkt-cost{font-size:.72rem;font-weight:700;color:var(--purple);}

/* ── OPEN BUTTON ── */
.open-btn{width:100%;padding:1rem;background:linear-gradient(135deg,var(--lemon-dark),#FF6F00);color:#fff;border:none;border-radius:var(--radius);font-family:var(--display);font-size:1.2rem;font-weight:600;cursor:pointer;transition:all .2s;box-shadow:0 4px 12px rgba(230,81,0,.3);}
.open-btn:hover{transform:translateY(-2px);box-shadow:0 6px 18px rgba(230,81,0,.4);}
.open-btn:disabled{background:#ccc;cursor:not-allowed;transform:none;box-shadow:none;}

/* ── DAY SUMMARY ── */
.summary-card{background:var(--surface);border:2px solid var(--border);border-radius:var(--radius);overflow:hidden;animation:popIn .4s ease;}
@keyframes popIn{from{opacity:0;transform:scale(.95)}to{opacity:1;transform:scale(1)}}
.summary-header{padding:1.25rem 1.5rem;display:flex;align-items:center;gap:1rem;}
.summary-day{font-family:var(--display);font-size:2.5rem;font-weight:600;line-height:1;flex-shrink:0;width:55px;}
.summary-title{font-family:var(--display);font-size:1.3rem;font-weight:600;margin-bottom:.2rem;}
.summary-sub{font-size:.78rem;color:var(--text-muted);}
.summary-body{padding:1.25rem 1.5rem;border-top:2px solid var(--border);}
.summary-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:.75rem;margin-bottom:1.25rem;}
.sum-box{background:var(--surface2);border:2px solid var(--border);border-radius:var(--radius-sm);padding:.85rem;text-align:center;}
.sum-icon{font-size:1.4rem;margin-bottom:.3rem;}
.sum-label{font-size:.62rem;font-weight:700;text-transform:uppercase;letter-spacing:.06em;color:var(--text-muted);margin-bottom:.2rem;}
.sum-val{font-family:var(--display);font-size:1.3rem;font-weight:600;}
.sum-val.pos{color:var(--green);}
.sum-val.neg{color:var(--red);}
.sum-val.neu{color:var(--lemon-dark);}

.event-banner{padding:.75rem 1rem;border-radius:var(--radius-sm);margin-bottom:1rem;font-size:.83rem;font-weight:600;display:flex;align-items:flex-start;gap:.6rem;line-height:1.45;}
.competition-alert{background:var(--redl);border:2px solid var(--red);color:var(--red);}
.event-good{background:var(--greenl);border:2px solid var(--green);color:var(--green);}
.event-bad{background:var(--redl);border:2px solid var(--red);color:var(--red);}
.event-neutral{background:var(--bluel);border:2px solid var(--blue);color:var(--blue);}

.lesson-box{background:var(--purplel);border:2px solid var(--purple);border-radius:var(--radius-sm);padding:.75rem 1rem;font-size:.8rem;color:var(--purple);line-height:1.5;margin-bottom:1rem;}

/* ── FINAL REPORT ── */
.final-report{background:var(--surface);border:2px solid var(--border);border-radius:var(--radius);overflow:hidden;}
.fr-header{background:var(--lemon-dark);color:#fff;padding:1.5rem;text-align:center;}
.fr-title{font-family:var(--display);font-size:2rem;font-weight:600;margin-bottom:.25rem;}
.fr-sub{font-size:.8rem;opacity:.8;}
.fr-body{padding:1.5rem;}
.fr-stats{display:grid;grid-template-columns:repeat(3,1fr);gap:1rem;margin-bottom:1.5rem;}
.fr-stat{text-align:center;padding:1rem;background:var(--surface2);border-radius:var(--radius-sm);border:2px solid var(--border);}
.fr-stat-val{font-family:var(--display);font-size:1.6rem;font-weight:600;margin-bottom:.2rem;}
.fr-stat-label{font-size:.65rem;font-weight:700;text-transform:uppercase;letter-spacing:.06em;color:var(--text-muted);}
.income-table{width:100%;border-collapse:collapse;font-size:.82rem;margin-bottom:1.25rem;}
.income-table th{text-align:left;padding:.5rem .75rem;background:var(--surface2);border:1px solid var(--border);font-size:.65rem;text-transform:uppercase;letter-spacing:.06em;color:var(--text-muted);}
.income-table td{padding:.55rem .75rem;border:1px solid var(--border);}
.income-table tr.total td{font-weight:700;background:var(--surface2);}
.income-table tr.profit-row td{font-weight:800;font-size:.9rem;}
.income-table td.pos{color:var(--green);}
.income-table td.neg{color:var(--red);}

.day-chart{display:flex;align-items:flex-end;gap:3px;height:80px;padding:0 .5rem;background:var(--surface2);border-radius:var(--radius-sm);border:1px solid var(--border);margin-bottom:1.25rem;}
.day-bar{flex:1;border-radius:3px 3px 0 0;transition:height .6s ease;min-height:2px;position:relative;}
.day-bar:hover::after{content:attr(data-tip);position:absolute;bottom:100%;left:50%;transform:translateX(-50%);background:var(--text);color:#fff;font-size:.6rem;padding:.2rem .45rem;border-radius:4px;white-space:nowrap;margin-bottom:4px;}

.fb-section{margin-top:1.25rem;padding-top:1.25rem;border-top:2px solid var(--border);}
.fb-label{font-size:.65rem;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:var(--text-muted);margin-bottom:.85rem;}
.fb-text{font-size:.86rem;line-height:1.8;color:var(--text);white-space:pre-wrap;}
.score-row{display:flex;gap:.4rem;flex-wrap:wrap;margin-bottom:1rem;}
.sc{font-size:.67rem;font-weight:700;padding:.25rem .75rem;border-radius:100px;}
.sc.great{background:var(--greenl);color:var(--green);border:1px solid rgba(46,125,50,.25);}
.sc.ok{background:var(--orangel);color:var(--orange);border:1px solid rgba(230,81,0,.25);}
.sc.needs{background:var(--redl);color:var(--red);border:1px solid rgba(198,40,40,.25);}

.typing-dot{display:inline-block;width:6px;height:6px;background:var(--lemon-dark);border-radius:50%;animation:blink 1.2s infinite;margin:0 2px;vertical-align:middle;}
.typing-dot:nth-child(2){animation-delay:.2s;}
.typing-dot:nth-child(3){animation-delay:.4s;}
@keyframes blink{0%,80%,100%{opacity:.15}40%{opacity:1}}

/* ── BUTTONS ── */
.btn{font-family:var(--body);font-size:.88rem;font-weight:700;padding:.65rem 1.4rem;border-radius:var(--radius-sm);border:none;cursor:pointer;transition:all .2s;}
.btn-primary{background:var(--lemon-dark);color:#fff;}
.btn-primary:hover{background:#E65100;transform:translateY(-1px);}
.btn-outline{background:transparent;color:var(--text);border:2px solid var(--border);}
.btn-outline:hover{border-color:var(--text-muted);}
.btn-row{display:flex;gap:.65rem;flex-wrap:wrap;margin-top:1rem;}

/* ── INTRO ── */
.intro-screen{max-width:560px;margin:2rem auto;padding:2rem;}
.intro-logo{font-size:4rem;text-align:center;margin-bottom:1rem;}
.intro-title{font-family:var(--display);font-size:2.2rem;font-weight:600;text-align:center;margin-bottom:.5rem;color:var(--lemon-dark);}
.intro-sub{text-align:center;color:var(--text-muted);margin-bottom:1.5rem;font-size:.9rem;line-height:1.65;}
.intro-card{background:var(--surface);border:2px solid var(--border);border-radius:var(--radius);padding:1.25rem;margin-bottom:1rem;}
.intro-card-title{font-family:var(--display);font-size:.95rem;font-weight:600;margin-bottom:.5rem;color:var(--lemon-dark);}
.intro-rules{display:flex;flex-direction:column;gap:.35rem;font-size:.83rem;line-height:1.5;}
.intro-rule{display:flex;align-items:flex-start;gap:.5rem;}
.loan-options{display:grid;grid-template-columns:1fr 1fr;gap:.75rem;margin-top:.75rem;}
.loan-opt{padding:.85rem;border:2px solid var(--border);border-radius:var(--radius-sm);cursor:pointer;transition:all .15s;text-align:center;}
.loan-opt:hover{border-color:var(--lemon-dark);}
.loan-opt.selected{border-color:var(--lemon-dark);background:var(--orangel);}
.loan-opt-name{font-family:var(--display);font-size:.95rem;font-weight:600;margin-bottom:.25rem;}
.loan-opt-desc{font-size:.68rem;color:var(--text-muted);line-height:1.4;}

/* ── SETUP ── */
.name-input{width:100%;padding:.75rem 1rem;font-family:var(--body);font-size:1rem;border:2px solid var(--border);border-radius:var(--radius-sm);outline:none;transition:border-color .15s;background:var(--surface);}
.name-input:focus{border-color:var(--lemon-dark);}

@media(max-width:768px){
  .game-body{grid-template-columns:1fr;}
  .summary-grid,.fr-stats,.supply-grid{grid-template-columns:1fr 1fr;}
  .game-header{gap:.65rem;}
}
</style>
</head>
<body>

<div id="app"></div>

<script>
const WORKER_URL="https://digitalmarketing.robert-nielson14.workers.dev";

// ── WEATHER SYSTEM ──
const WEATHER_TYPES={
  sunny:{icon:'☀️',name:'Sunny',temp:'85°F',demandMult:1.3,desc:'Perfect lemonade weather!',rain:false,bg:'linear-gradient(180deg,#87CEEB 0%,#B0E2FF 60%,#4CAF50 60%,#388E3C 100%)'},
  hot:{icon:'🌡️',name:'Hot & Sunny',temp:'95°F',demandMult:1.6,desc:'Scorching hot — people are thirsty!',rain:false,bg:'linear-gradient(180deg,#FF8C00 0%,#FFD700 50%,#4CAF50 60%,#388E3C 100%)'},
  cloudy:{icon:'⛅',name:'Partly Cloudy',temp:'72°F',demandMult:0.9,desc:'Mild day — decent traffic.',rain:false,bg:'linear-gradient(180deg,#9E9E9E 0%,#B0BEC5 55%,#4CAF50 60%,#388E3C 100%)'},
  overcast:{icon:'☁️',name:'Overcast',temp:'65°F',demandMult:0.65,desc:'Gray skies — fewer customers out.',rain:false,bg:'linear-gradient(180deg,#607D8B 0%,#90A4AE 55%,#4CAF50 60%,#388E3C 100%)'},
  rainy:{icon:'🌧️',name:'Rainy',temp:'58°F',demandMult:0.3,desc:'Rain keeps customers away.',rain:true,bg:'linear-gradient(180deg,#455A64 0%,#78909C 55%,#558B2F 60%,#33691E 100%)'},
  windy:{icon:'💨',name:'Windy',temp:'70°F',demandMult:0.75,desc:'Wind makes signs hard to read.',rain:false,bg:'linear-gradient(180deg,#78909C 0%,#90A4AE 55%,#4CAF50 60%,#388E3C 100%)'},
  perfect:{icon:'🌈',name:'Beautiful Day',temp:'78°F',demandMult:1.5,desc:'Gorgeous day — huge demand!',rain:false,bg:'linear-gradient(180deg,#64B5F6 0%,#81C784 55%,#4CAF50 60%,#388E3C 100%)'},
};

const WEATHER_SCHEDULE=['sunny','cloudy','hot','rainy','perfect','sunny','overcast','hot','windy','rainy','sunny','perfect','cloudy','hot'];

// ── LOCATIONS ──
const LOCATIONS=[
  {id:'corner',emoji:'🏘️',name:'Neighborhood',bonus:'Loyal regulars',mult:1.0,desc:'Steady but small crowd'},
  {id:'park',emoji:'🌳',name:'City Park',bonus:'+30% weekends',mult:1.2,desc:'Great foot traffic'},
  {id:'school',emoji:'🏫',name:'Near School',bonus:'After school rush',mult:1.15,desc:'Big rush 3-4pm'},
  {id:'beach',emoji:'🏖️',name:'Beach/Pool',bonus:'Hot weather bonus',mult:1.1,desc:'Amazing on hot days'},
  {id:'market',emoji:'🛒',name:'Farmers Market',bonus:'Premium buyers',mult:1.25,desc:'Sat/Sun only — big sales'},
  {id:'event',emoji:'🎪',name:'Event Venue',bonus:'Random events',mult:1.35,desc:'High risk, high reward'},
];

// ── RANDOM EVENTS ──
const RANDOM_EVENTS=[
  {day:3,type:'good',icon:'🎉',title:'Street Fair Nearby!',desc:'A block party doubles foot traffic today.',effect:{demandMult:1.8},lesson:'Unexpected demand spikes happen. Did you have enough supply?'},
  {day:5,type:'bad',icon:'📋',title:'Health Permit Required',desc:'Inspector requires a $10 sanitation permit.',effect:{cashPenalty:10},lesson:'Regulatory compliance (Strand 7) costs money. Build permits into your startup budget.'},
  {day:7,type:'neutral',icon:'☀️',title:'Heat Wave!',desc:'Temperatures spiked 15 degrees today.',effect:{demandBonus:0.4},lesson:'External factors you cannot control (PEST analysis) directly affect demand.'},
  {day:9,type:'bad',icon:'🚚',title:'Supplier Shortage',desc:'Cup supplier is out of stock. Cups cost 2x today.',effect:{cupCostMult:2},lesson:'Supply chain disruptions are real. Did you buy extra yesterday?'},
  {day:11,type:'good',icon:'📱',title:'Your Stand Goes Viral!',desc:'Someone posted about your lemonade. Traffic up 50%.',effect:{demandMult:1.5},lesson:'Word-of-mouth marketing (earned media) is free and powerful.'},
  {day:13,type:'neutral',icon:'🎓',title:'Field Trip Passes By',desc:'A school bus stops — 40 potential customers.',effect:{demandBonus:0.35},lesson:'Location matters. Being in the right place at the right time is strategy, not luck.'},
];

// ── COMPETITION ──
const COMPETITION_DAY=4;

// ── SUPPLY PRICES ──
const BASE_PRICES={lemons:0.5,sugar:0.3,cups:0.2,water:0.1};
const BULK_DISCOUNT={lemons:{qty:20,price:0.35},sugar:{qty:30,price:0.22},cups:{qty:50,price:0.14}};

// ── MARKETING OPTIONS ──
